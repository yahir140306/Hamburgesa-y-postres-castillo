---
// No props needed
---

<nav
  class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 pb-safe pt-2 px-6 flex justify-center items-center z-50 shadow-[0_-5px_20px_rgba(0,0,0,0.05)]"
>
  <div class="relative -top-6">
    <a href="/carrito">
      <button
        class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg shadow-orange-500/40 border-4 border-white transform hover:scale-105 transition-transform"
      >
        <span class="material-icons-round">shopping_bag</span>
        <span
          class="cart-badge absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs font-bold flex items-center justify-center border-2 border-white"
          style="display: none;"></span>
      </button>
    </a>
  </div>
</nav>

<script>
  interface CartItem {
    nombre: string;
    precio: number | string;
    cantidad: number;
    descripcion: string;
    imagen?: string;
  }

  function updateCartBadge() {
    const cart = localStorage.getItem("cart");
    const cartItems: CartItem[] = cart ? JSON.parse(cart) : [];
    const count = cartItems.reduce((sum, item) => sum + item.cantidad, 0);
    const badge = document.querySelector(".cart-badge") as HTMLElement;

    if (badge) {
      if (count > 0) {
        badge.textContent = count.toString();
        badge.style.display = "flex";
      } else {
        badge.style.display = "none";
      }
    }
  }

  // Update on load
  document.addEventListener("DOMContentLoaded", updateCartBadge);

  // Update when storage changes (from another tab/window)
  window.addEventListener("storage", (e) => {
    if (e.key === "cart") {
      updateCartBadge();
    }
  });

  // Update periodically to catch same-window changes
  setInterval(updateCartBadge, 500);
</script>
