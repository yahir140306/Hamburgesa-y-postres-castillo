    precio: 55,
    descripcion: "Carne 100% res, queso americano, vegetales frescos.",
    imagen:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuA_wdyYusz-nrMt1tAxD7IPsDWLyy84w6eMi2ZtzLKIbe9VeiqvGbr9BINQu60r4JsRxYrSK5zw1LUCXAItKRyCcicHgLo1uUyyFww1uOcIupUHg_49KeMMtJGSYEeCgJ0WF68JcwC00W2-ZDhXPAYI0MQYkY_ctCCAkedwImHDf9k90zHJDQK5lC7EjZxQN3jehdQ7kVOVHieAd17Z_ZrAPPx3Gu4b0qdwFbxRXMm9CKwx5AuJDgNzCAPbi_gyqID1O86jSLMZHw",
  },
  {
    nombre: "Hawaiana",
    precio: 65,
    descripcion: "Piña asada a la parrilla y jamón extra de pavo.",
    imagen:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuAeNS3BnbDZ9e3oO8yB1o5sZB86_1GN5SxtoJGlqPlMINSbiqHbt-EO0piQm4WTgASxqqzXxN_RZDGbImlkKoohV4SxakoZNyCaKxeCSxrZWJdakBcJfCEONBUPDO8NAjZ5LBlG1-vS_28KHTOqkVDDPuqVAe1LOQpdiL9xvmE5uZgZuMrNCFbGHQkFkiw_6Wpos1j5lW-saFPUYP9XZSipFR-lzUpRqQB-7qn2RDsFZqHJcjo3jiWiZWxVKsy7fXMneBsioz_Xag",
