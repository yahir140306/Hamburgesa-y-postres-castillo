const bebidas = [
  { nombre: "Malteadas (Varios Sabores)", precio: 50 },
  { nombre: "Refrescos (Variedad)", precio: 25 },
  { nombre: "Té Helado o Caliente", precio: 20 },
  { nombre: "Chocolate Caliente", precio: 30 },
