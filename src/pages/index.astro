const postres = [
  { nombre: "Plátanos Fritos", precio: 25 },
  { nombre: "Fresas c/Crema", precio: 35 },
  { nombre: "Pay de Limón", precio: 30 },
  { nombre: "Flan Casero", precio: 30 },
  { nombre: "Mini Hot Cakes", precio: 35 },
  { nombre: "Gomitas", precio: "15 - 25" },
