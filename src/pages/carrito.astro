---
import "../styles/global.css";

interface CartItem {
  nombre: string;
  precio: number;
  cantidad: number;
  descripcion: string;
  imagen?: string;
}

const cartItems: CartItem[] = [
  {
    nombre: "Sencilla",
    precio: 55,
    cantidad: 1,
    descripcion: "Carne 100% res, queso, vegetales.",
    imagen:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuBQDon9gqoLq3cvNYNKqV4nrvTAwD1oGaUKdu5WaIP3D_218_xhc6-zhPqs5DtXS9YR-S1W1SYouhaCq_NFGImkzFl2rTlsCPGaLf76F-fmEU5MpZnJB0oWC2dVb-kJS_zCYG2X57qcBirrBxri44BiRX9p-1bJ6hSdygb8ow55BxKr0YHG0jjeI0Kr0U-dcsFgZt90VPF8R0waZjSJZmmqVVqUp0Od_Kg0brK_BDkv-6k57S9JkJIhFFaIvxLFcF3oCwXEYiBDxw",
  },
  {
    nombre: "Plátanos Fritos",
    precio: 25,
    cantidad: 2,
    descripcion: "Orden doble, crujientes y dulces.",
    imagen:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuDeFUNJ1RZiCP1k6re9ykREMXotrFar0FrqWZfU61xj_p_uLIXSCmO7udTVUEqb4Tbibtc6-YZZmU4Tjxbl6zbBCS1nysFRtVYiHtwObPrpVUPW7eSerIlDfk3eBwY_WJ4Pv_u1os-ps_hT_BDhvWrSgBQUoGZdKUVIFHKmuC5kzWaSjh4fMG9kXB2kGcFWq1AzaKSWAOpjOZFpPIs3ea_UmtHH7YjCmvYrOXuZDluwKgFvcUhehL3JNVYEkOzE-5j-2dMg6Up7Mg",
  },
  {
    nombre: "Coca Cola",
    precio: 25,
    cantidad: 1,
    descripcion: "600ml, bien fría.",
  },
];

const subtotal = cartItems.reduce(
  (acc, item) => acc + item.precio * item.cantidad,
  0,
);
const envio = 0;
const total = subtotal + envio;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Resumen del Carrito - Hamburguesas Castillo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <style>
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.5);
        border-radius: 20px;
      }
    </style>
  </head>
  <body class="bg-background-light min-h-screen flex justify-center text-main-light transition-colors duration-200"
  >
    <div class="w-full max-w-md bg-background-light min-h-screen relative shadow-2xl overflow-hidden flex flex-col"
    >
      <!-- Header -->
      <header class="sticky top-0 z-20 bg-background-light/95 backdrop-blur-sm px-6 py-4 flex items-center justify-between border-b border-gray-200"
      >
        <a
          href="/"
          aria-label="Regresar" class="p-2 -ml-2 rounded-full hover:bg-gray-100 transition-colors"
        >
          <span class="material-symbols-outlined text-gray-800"
            >arrow_back</span
          >
        </a>
        <h1 class="text-lg font-bold text-gray-900">
          Tu Pedido
        </h1>
        <button class="p-2 -mr-2 rounded-full hover:bg-gray-100 transition-colors text-primary font-medium text-sm"
        >
          Limpiar
        </button>
      </header>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto px-6 py-4 space-y-6 pb-32">
        <!-- Cart Items -->
        <div class="space-y-4">
          {
            cartItems.map((item) => (
              <div class="bg-white p-4 rounded-2xl shadow-sm flex items-center gap-4 border border-gray-100">
                <div class="w-20 h-20 shrink-0 bg-gray-100 rounded-xl overflow-hidden">
                  {item.imagen ? (
                    <img
                      alt={item.nombre} class="w-full h-full object-cover"
                      src={item.imagen}
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-primary">
                      <span class="material-symbols-outlined text-3xl">
                        local_drink
                      </span>
                    </div>
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between items-start mb-1">
                    <h3 class="font-bold text-gray-900 truncate pr-2">
                      {item.nombre}
                    </h3>
                    <span class="font-bold text-primary">
                      ${item.precio}
                    </span>
                  </div>
                  <p class="text-xs text-sub-light mb-3 line-clamp-1">
                    {item.descripcion}
                  </p>
                  <div class="flex items-center gap-3">
                    <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">
                      <span class="material-symbols-outlined text-sm font-bold">
                        remove
                      </span>
                    </button>
                    <span class="text-sm font-semibold w-4 text-center">
                      {item.cantidad}
                    </span>
                    <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-primary text-white hover:bg-primary-dark transition-colors shadow-sm">
                      <span class="material-symbols-outlined text-sm font-bold">
                        add
                      </span>
                    </button>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Notes Section -->
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100"
        >
          <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2"
            for="notes"
          >
            <span class="material-symbols-outlined text-base">edit_note</span>
            Notas adicionales
          </label>
          <textarea class="w-full bg-background-light border-gray-200 rounded-xl text-sm focus:ring-[--color-primary] focus:border-[--color-primary] placeholder-gray-400 p-3 resize-none"
            id="notes"
            placeholder="Ej: Sin cebolla, extra salsa..."
            rows="2"></textarea>
        </div>

        <!-- Info Banner -->
        <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100 flex items-start gap-3"
        >
          <span class="material-symbols-outlined text-blue-600 mt-0.5"
            >info</span
          >
          <div class="text-sm text-blue-800">
            <p class="font-medium">Tiempo estimado: 30-45 min</p>
            <p class="text-xs mt-1 opacity-80">
              El envío es gratis en la zona centro.
            </p>
          </div>
        </div>
      </main>

      <!-- Bottom Summary & CTA -->
      <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] p-6 rounded-t-3xl z-30"
      >
        <div class="space-y-3 mb-6">
          <div class="flex justify-between items-center text-sm text-sub-light"
          >
            <span>Subtotal</span>
            <span>${subtotal}</span>
          </div>
          <div class="flex justify-between items-center text-sm text-sub-light"
          >
            <span>Envío</span>
            <span class="text-green-600 font-medium"
              >¡Gratis!</span
            >
          </div>
          <div class="h-px bg-gray-100 my-2"></div>
          <div class="flex justify-between items-center text-xl font-bold text-gray-900"
          >
            <span>Total</span>
            <span>${total}</span>
          </div>
        </div>
        <a
          href="https://wa.me/5511740626?text=Hola,%20quiero%20hacer%20un%20pedido"
          target="_blank"
          rel="noopener noreferrer"
        >
          <button class="w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 px-6 rounded-2xl shadow-lg shadow-green-200 flex items-center justify-center gap-3 transition-all transform active:scale-95"
          >
            <svg class="w-6 h-6 fill-current"
              viewBox="0 0 448 512"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
              ></path>
            </svg>
            Hacer pedido por WhatsApp
          </button>
        </a>
      </div>
    </div>
  </body>
</html>
