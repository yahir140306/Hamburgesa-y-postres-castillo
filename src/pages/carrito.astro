---
import "../styles/global.css";

interface CartItem {
  nombre: string;
  precio: number | string;
  cantidad: number;
  descripcion: string;
  imagen?: string;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Resumen del Carrito - Hamburguesas Castillo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <style>
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.5);
        border-radius: 20px;
      }
    </style>
  </head>
  <body
    class="bg-background-light min-h-screen flex justify-center text-main-light transition-colors duration-200"
  >
    <div
      class="w-full max-w-md bg-background-light min-h-screen relative shadow-2xl overflow-hidden flex flex-col"
    >
      <!-- Header -->
      <header
        class="sticky top-0 z-20 bg-background-light/95 backdrop-blur-sm px-6 py-4 flex items-center justify-between border-b border-gray-200"
      >
        <a
          href="/"
          aria-label="Regresar"
          class="p-2 -ml-2 rounded-full hover:bg-gray-100 transition-colors"
        >
          <span class="material-symbols-outlined text-gray-800">arrow_back</span
          >
        </a>
        <h1 class="text-lg font-bold text-gray-900">Tu Pedido</h1>
        <button
          class="p-2 -mr-2 rounded-full hover:bg-gray-100 transition-colors text-primary font-medium text-sm"
          id="clear-cart"
        >
          Limpiar
        </button>
      </header>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto px-6 py-4 space-y-6 pb-32">
        <!-- Empty Cart Message -->
        <div
          id="empty-cart"
          class="flex flex-col items-center justify-center py-16 text-center"
          style="display: none;"
        >
          <span class="material-symbols-outlined text-gray-300 text-8xl mb-4"
            >shopping_cart</span
          >
          <h3 class="text-xl font-bold text-gray-700 mb-2">
            Tu carrito está vacío
          </h3>
          <p class="text-gray-500 mb-6">
            Agrega productos del menú para empezar tu pedido
          </p>
          <a
            href="/"
            class="bg-primary hover:bg-primary-dark text-white font-bold py-3 px-6 rounded-xl transition-colors"
          >
            Ver Menú
          </a>
        </div>

        <!-- Cart Items -->
        <div id="cart-items" class="space-y-4"></div>

        <!-- Notes Section -->
        <div
          id="notes-section"
          class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100"
          style="display: none;"
        >
          <label
            class="flex items-center gap-2 text-sm font-medium text-gray-700 mb-2"
            for="notes"
          >
            <span class="material-symbols-outlined text-base">edit_note</span>
            Notas adicionales
          </label>
          <textarea
            class="w-full bg-background-light border-gray-200 rounded-xl text-sm focus:ring-[--color-primary] focus:border-[--color-primary] placeholder-gray-400 p-3 resize-none"
            id="notes"
            placeholder="Ej: Sin cebolla, extra salsa..."
            rows="2"></textarea>
        </div>

        <!-- Info Banner -->
        <div
          id="info-banner"
          class="bg-blue-50 p-4 rounded-2xl border border-blue-100 flex items-start gap-3"
          style="display: none;"
        >
          <span class="material-symbols-outlined text-blue-600 mt-0.5"
            >info</span
          >
          <div class="text-sm text-blue-800">
            <p class="font-medium">Tiempo estimado: 30-45 min</p>
            <p class="text-xs mt-1 opacity-80">
              El envío es gratis en la zona centro.
            </p>
          </div>
        </div>
      </main>

      <!-- Bottom Summary & CTA -->
      <div
        id="cart-summary"
        class="absolute bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] p-6 rounded-t-3xl z-30"
        style="display: none;"
      >
        <div class="space-y-3 mb-6">
          <div class="flex justify-between items-center text-sm text-sub-light">
            <span>Subtotal</span>
            <span id="subtotal">$0</span>
          </div>
          <div class="flex justify-between items-center text-sm text-sub-light">
            <span>Envío</span>
            <span class="text-green-600 font-medium">¡Gratis!</span>
          </div>
          <div class="h-px bg-gray-100 my-2"></div>
          <div
            class="flex justify-between items-center text-xl font-bold text-gray-900"
          >
            <span>Total</span>
            <span id="total">$0</span>
          </div>
        </div>
        <button
          id="whatsapp-button"
          class="w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 px-6 rounded-2xl shadow-lg shadow-green-200 flex items-center justify-center gap-3 transition-all transform active:scale-95"
        >
          <svg
            class="w-6 h-6 fill-current"
            viewBox="0 0 448 512"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
            ></path>
          </svg>
          Hacer pedido por WhatsApp
        </button>
      </div>
    </div>

    <script>
      interface CartItem {
        nombre: string;
        precio: number | string;
        cantidad: number;
        descripcion: string;
        imagen?: string;
      }

      function getCart(): CartItem[] {
        const cart = localStorage.getItem("cart");
        return cart ? JSON.parse(cart) : [];
      }

      function saveCart(cart: CartItem[]) {
        localStorage.setItem("cart", JSON.stringify(cart));
        renderCart();
      }

      function updateQuantity(nombre: string, delta: number) {
        const cart = getCart();
        const item = cart.find((i) => i.nombre === nombre);

        if (item) {
          item.cantidad += delta;
          if (item.cantidad <= 0) {
            const index = cart.indexOf(item);
            cart.splice(index, 1);
          }
          saveCart(cart);
        }
      }

      function clearCart() {
        if (confirm("¿Estás seguro de que quieres vaciar el carrito?")) {
          localStorage.removeItem("cart");
          renderCart();
        }
      }

      function getPrecioNumerico(precio: number | string): number {
        if (typeof precio === "number") return precio;
        // Extract first number from strings like "Desde $35" or "15 - 25"
        const match = precio.match(/\d+/);
        return match ? parseInt(match[0]) : 0;
      }

      function renderCart() {
        const cart = getCart();
        const cartItemsContainer = document.getElementById("cart-items");
        const emptyCart = document.getElementById("empty-cart");
        const notesSection = document.getElementById("notes-section");
        const infoBanner = document.getElementById("info-banner");
        const cartSummary = document.getElementById("cart-summary");

        console.log("Rendering cart:", cart); // Debug log

        if (!cartItemsContainer || !emptyCart) {
          console.error("Required elements not found");
          return;
        }

        if (cart.length === 0) {
          console.log("Cart is empty");
          emptyCart.style.cssText = "display: flex !important;";
          cartItemsContainer.innerHTML = "";
          if (notesSection)
            notesSection.style.cssText = "display: none !important;";
          if (infoBanner)
            infoBanner.style.cssText = "display: none !important;";
          if (cartSummary)
            cartSummary.style.cssText = "display: none !important;";
          return;
        }

        console.log("Cart has items:", cart.length);
        emptyCart.style.cssText = "display: none !important;";
        if (notesSection)
          notesSection.style.cssText = "display: block !important;";
        if (infoBanner) infoBanner.style.cssText = "display: flex !important;";
        if (cartSummary)
          cartSummary.style.cssText = "display: block !important;";

        cartItemsContainer.innerHTML = cart
          .map(
            (item) => `
          <div class="bg-white p-4 rounded-2xl shadow-sm flex items-center gap-4 border border-gray-100">
            <div class="w-20 h-20 shrink-0 bg-gray-100 rounded-xl overflow-hidden">
              ${
                item.imagen
                  ? `<img alt="${item.nombre}" class="w-full h-full object-cover" src="${item.imagen}" />`
                  : `<div class="w-full h-full flex items-center justify-center text-primary">
                       <span class="material-symbols-outlined text-3xl">restaurant</span>
                     </div>`
              }
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-start mb-1">
                <h3 class="font-bold text-gray-900 truncate pr-2">${item.nombre}</h3>
                <span class="font-bold text-primary">$${getPrecioNumerico(item.precio)}</span>
              </div>
              <p class="text-xs text-sub-light mb-3 line-clamp-1">${item.descripcion}</p>
              <div class="flex items-center gap-3">
                <button 
                  class="w-7 h-7 flex items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors"
                  onclick="window.updateQuantity('${item.nombre.replace(/'/g, "\\'")}', -1)"
                >
                  <span class="material-symbols-outlined text-sm font-bold">remove</span>
                </button>
                <span class="text-sm font-semibold w-4 text-center">${item.cantidad}</span>
                <button 
                  class="w-7 h-7 flex items-center justify-center rounded-lg bg-primary text-white hover:bg-primary-dark transition-colors shadow-sm"
                  onclick="window.updateQuantity('${item.nombre.replace(/'/g, "\\'")}', 1)"
                >
                  <span class="material-symbols-outlined text-sm font-bold">add</span>
                </button>
              </div>
            </div>
          </div>
        `,
          )
          .join("");

        // Calculate totals
        const subtotal = cart.reduce(
          (sum, item) => sum + getPrecioNumerico(item.precio) * item.cantidad,
          0,
        );
        const total = subtotal;

        const subtotalEl = document.getElementById("subtotal");
        const totalEl = document.getElementById("total");

        if (subtotalEl) subtotalEl.textContent = `$${subtotal}`;
        if (totalEl) totalEl.textContent = `$${total}`;

        // Update WhatsApp message
        updateWhatsAppLink(cart, total);
      }

      function updateWhatsAppLink(cart: CartItem[], total: number) {
        const whatsappButton = document.getElementById(
          "whatsapp-button",
        ) as HTMLButtonElement;
        if (!whatsappButton) return;

        const notes =
          (document.getElementById("notes") as HTMLTextAreaElement)?.value ||
          "";

        let message = "Hola, quiero hacer el siguiente pedido:\n\n";
        cart.forEach((item) => {
          message += `• ${item.cantidad}x ${item.nombre} - $${getPrecioNumerico(item.precio) * item.cantidad}\n`;
        });
        message += `\n*Total: $${total}*`;
        if (notes) {
          message += `\n\nNotas: ${notes}`;
        }

        whatsappButton.onclick = () => {
          window.open(
            `https://wa.me/5511740626?text=${encodeURIComponent(message)}`,
            "_blank",
          );
        };
      }

      // Make functions available globally
      (window as any).updateQuantity = updateQuantity;
      (window as any).clearCart = clearCart;

      // Initialize
      document.addEventListener("DOMContentLoaded", () => {
        // Add a small delay to ensure everything is ready
        setTimeout(() => {
          console.log("Initializing cart page");
          renderCart();
        }, 100);

        // Clear cart button
        document
          .getElementById("clear-cart")
          ?.addEventListener("click", clearCart);

        // Update WhatsApp link when notes change
        document.getElementById("notes")?.addEventListener("input", () => {
          const cart = getCart();
          const subtotal = cart.reduce(
            (sum, item) => sum + getPrecioNumerico(item.precio) * item.cantidad,
            0,
          );
          updateWhatsAppLink(cart, subtotal);
        });
      });
    </script>
  </body>
</html>
